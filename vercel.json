{
  "version": 2,
  "functions": {
    "api/server.js": {
      "maxDuration": 10
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/server.js"
    },
    {
      "source": "/Public/(.*)",
      "destination": "/Public/$1"
    },
    {
      "source": "/images/(.*)",
      "destination": "/Public/images/$1"
    },
    {
      "source": "/style.css",
      "destination": "/style.css"
    },
    {
      "source": "/(.*\\.js)",
      "destination": "/$1"
    },
    {
      "source": "/(.*\\.png)",
      "destination": "/$1"
    },
    {
      "source": "/(.*\\.jpg)",
      "destination": "/$1"
    },
    {
      "source": "/(.*\\.jpeg)",
      "destination": "/$1"
    },
    {
      "source": "/(.*\\.gif)",
      "destination": "/$1"
    },
    {
      "source": "/(.*\\.svg)",
      "destination": "/$1"
    },
    {
      "source": "/(.*\\.ico)",
      "destination": "/$1"
    },
    {
      "source": "/(.*\\.woff)",
      "destination": "/$1"
    },
    {
      "source": "/(.*\\.woff2)",
      "destination": "/$1"
    },
    {
      "source": "/(.*\\.ttf)",
      "destination": "/$1"
    },
    {
      "source": "/(.*\\.eot)",
      "destination": "/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/api/server.js"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/style.css",
      "headers": [
        {
          "key": "Content-Type",
          "value": "text/css"
        }
      ]
    },
    {
      "source": "/Public/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400"
        }
      ]
    }
  ]
}
